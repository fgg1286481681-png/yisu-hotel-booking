{
  "name": "yisu-hotel-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal backend for yisu hotel booking, built with Express + TypeScript + Prisma + SQLite.",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "svg-captcha": "^1.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.13.4",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
